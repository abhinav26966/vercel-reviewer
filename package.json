{
  "name": "flowguard",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:up": "docker compose up -d postgres redis minio minio-init",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "eslint": "^9.39.4",
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
