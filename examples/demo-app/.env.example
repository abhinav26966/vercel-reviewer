# Demo app configuration. Copy to .env.local for local dev (all defaults work).

# Signs the demo session cookie. Set a real value on Vercel.
SESSION_SECRET=dev-secret-do-not-use-in-prod

# Password for the seeded users default@demo.dev / premium@demo.dev.
DEMO_PASSWORD=demo1234

# 1 = skip Stripe entirely (purchases succeed immediately). Also implied when
# STRIPE_SECRET_KEY is unset.
MOCK_PAYMENTS=1

# Stripe TEST-mode keys (sk_test_...). Only needed when MOCK_PAYMENTS is off.
# STRIPE_SECRET_KEY=
