# Copy to .env.production and fill in. NEVER commit .env.production.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production

# ── generated locally ───────────────────────────────────────────────────────
# openssl rand -hex 32   (vault master key — losing it means re-entering all secrets)
FLOWGUARD_MASTER_KEY=
# openssl rand -hex 16   (internal service passwords)
POSTGRES_PASSWORD=
MINIO_PASSWORD=

# ── your GitHub App (SELF_HOSTING.md §2) ────────────────────────────────────
GITHUB_APP_ID=
# base64 of the downloaded .pem:  base64 -i app-key.pem | tr -d '\n'
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# ── inference (any OpenAI-compatible provider; OpenRouter recommended) ──────
INFERENCE_API_KEY=
# leave empty for platform defaults (free models — flaky vision); recommended:
INFERENCE_ANALYZE_MODELS=anthropic/claude-haiku-4.5
INFERENCE_GROUNDING_MODELS=anthropic/claude-haiku-4.5
INFERENCE_JUDGE_MODELS=anthropic/claude-haiku-4.5

# ── public URLs (where users + GitHub reach this instance) ──────────────────
# With the caddy profile: https://your-api-domain / https://your-dash-domain
# Without TLS (trying it out): http://<machine-ip>:8787 / http://<machine-ip>:3100
PUBLIC_API_URL=
PUBLIC_DASHBOARD_URL=
# only used by the caddy profile:
API_DOMAIN=
DASHBOARD_DOMAIN=

# ── optional ────────────────────────────────────────────────────────────────
API_PORT=8787
DASHBOARD_PORT=3100
LOG_LEVEL=info
