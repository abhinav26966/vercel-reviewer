{
  "name": "@flowguard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx watch src/server.ts",
    "dev:webhooks": "smee --url $SMEE_URL --target http://localhost:8787/webhooks/github",
    "seed:project": "tsx scripts/seed-project.ts"
  },
  "dependencies": {
    "@flowguard/db": "workspace:*",
    "@flowguard/github": "workspace:*",
    "@flowguard/schemas": "workspace:*",
    "@flowguard/shared": "workspace:*",
    "@flowguard/vercel": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "smee-client": "^5.0.0",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  }
}
