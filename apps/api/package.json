{
  "name": "@flowguard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:webhooks": "tsx --env-file=.env scripts/smee.ts",
    "seed:project": "tsx --env-file=.env scripts/seed-project.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1081.0",
    "@fastify/multipart": "^9.4.0",
    "fflate": "^0.8.2",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@flowguard/db": "workspace:*",
    "@flowguard/github": "workspace:*",
    "@flowguard/schemas": "workspace:*",
    "@flowguard/shared": "workspace:*",
    "@flowguard/vercel": "workspace:*",
    "bullmq": "^5.79.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.6.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "smee-client": "^5.0.0",
    "tsx": "^4.20.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  }
}
