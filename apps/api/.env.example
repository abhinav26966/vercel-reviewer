# FlowGuard control plane. Copy to .env (gitignored).

PORT=8787
DATABASE_URL=postgres://flowguard:flowguard@localhost:5433/flowguard

# GitHub App (SETUP.md item 4)
GITHUB_APP_ID=
# base64 of the downloaded .pem:  base64 -i flowguard-dev.private-key.pem
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# 32-byte master key for the secrets vault:  openssl rand -hex 32
FLOWGUARD_MASTER_KEY=

# smee.io channel for local webhook forwarding (SETUP.md item 4)
SMEE_URL=
