{
  "specVersion": 3,
  "flowId": "flw_rip_broken",
  "projectId": "prj_862ymcrku4xal4",
  "name": "Buy & Rip (chaos: break=rip)",
  "description": "rip flow with ?break=rip \u2014 must fail at s6. CLI verification artifact.",
  "tier": "standard",
  "persona": "default",
  "startPath": "/shop",
  "env": {
    "requiresWebGL": true
  },
  "steps": [
    {
      "id": "s4",
      "title": "Buy a pack",
      "intent": "Purchase one pack so there is something to open",
      "action": {
        "type": "click",
        "locators": [
          {
            "kind": "testid",
            "value": "buy-pack-btn"
          },
          {
            "kind": "role",
            "value": {
              "role": "button",
              "name": "Buy Pack"
            }
          }
        ]
      },
      "settle": {
        "strategy": "navigation",
        "timeoutMs": 20000
      },
      "postConditions": [
        {
          "kind": "url",
          "assert": "pathMatches",
          "value": "^/shop/success$"
        },
        {
          "kind": "dom",
          "assert": "visible",
          "locators": [
            {
              "kind": "testid",
              "value": "purchase-complete"
            },
            {
              "kind": "text",
              "value": "Purchase complete"
            }
          ]
        }
      ],
      "timingBaselineKey": "s4"
    },
    {
      "id": "s5",
      "title": "Open the pack page",
      "action": {
        "type": "navigate",
        "path": "/open?break=rip"
      },
      "settle": {
        "strategy": "networkidle",
        "timeoutMs": 10000
      },
      "postConditions": [
        {
          "kind": "dom",
          "assert": "visible",
          "locators": [
            {
              "kind": "testid",
              "value": "pack-canvas"
            },
            {
              "kind": "css",
              "value": "canvas"
            }
          ],
          "description": "WebGL canvas rendered"
        }
      ]
    },
    {
      "id": "s5b",
      "title": "Scene warm-up",
      "intent": "Give the WebGL scene time to initialize under software rendering \u2014 replaced by animationQuiescence settle in Phase 12",
      "action": {
        "type": "waitFor",
        "locators": [
          {
            "kind": "testid",
            "value": "pack-canvas"
          },
          {
            "kind": "css",
            "value": "canvas"
          }
        ],
        "state": "visible"
      },
      "settle": {
        "strategy": "timeout",
        "timeoutMs": 2000
      }
    },
    {
      "id": "s6",
      "title": "Rip open the pack",
      "intent": "Click the pack in the 3D scene; the open API must succeed",
      "action": {
        "type": "click",
        "locators": [
          {
            "kind": "testid",
            "value": "pack-canvas"
          },
          {
            "kind": "css",
            "value": "canvas"
          }
        ]
      },
      "settle": {
        "strategy": "networkidle",
        "timeoutMs": 10000
      },
      "postConditions": [
        {
          "kind": "dom",
          "assert": "hidden",
          "locators": [
            {
              "kind": "testid",
              "value": "open-error"
            }
          ],
          "description": "No open-error banner \u2014 the rip API call succeeded"
        },
        {
          "kind": "dom",
          "assert": "textMatches",
          "locators": [
            {
              "kind": "testid",
              "value": "packs-remaining"
            }
          ],
          "value": "^0$",
          "description": "The purchased pack was consumed (bought 1, opened 1)"
        }
      ],
      "timingBaselineKey": "s6"
    }
  ]
}