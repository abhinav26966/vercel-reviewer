{
  "specVersion": 3,
  "flowId": "flw_login",
  "projectId": "prj_862ymcrku4xal4",
  "name": "Login",
  "description": "Log in with the seeded default persona and land on the shop. Credentials come from the vault via {{secret:*}} placeholders \u2014 never plaintext in specs.",
  "tier": "smoke",
  "persona": null,
  "startPath": "/login",
  "steps": [
    {
      "id": "s1",
      "title": "Enter email",
      "action": {
        "type": "type",
        "locators": [
          {
            "kind": "testid",
            "value": "email-input"
          },
          {
            "kind": "css",
            "value": "input[type=email]"
          }
        ],
        "value": "{{secret:default.username}}"
      },
      "settle": {
        "strategy": "timeout",
        "timeoutMs": 100
      }
    },
    {
      "id": "s2",
      "title": "Enter password",
      "action": {
        "type": "type",
        "locators": [
          {
            "kind": "testid",
            "value": "password-input"
          },
          {
            "kind": "css",
            "value": "input[type=password]"
          }
        ],
        "value": "{{secret:default.password}}"
      },
      "settle": {
        "strategy": "timeout",
        "timeoutMs": 100
      }
    },
    {
      "id": "s3",
      "title": "Submit login",
      "intent": "Authenticate and land on the shop",
      "action": {
        "type": "click",
        "locators": [
          {
            "kind": "testid",
            "value": "login-submit"
          },
          {
            "kind": "role",
            "value": {
              "role": "button",
              "name": "Log in"
            }
          }
        ]
      },
      "settle": {
        "strategy": "navigation",
        "timeoutMs": 15000
      },
      "postConditions": [
        {
          "kind": "url",
          "assert": "pathMatches",
          "value": "^/shop$"
        },
        {
          "kind": "dom",
          "assert": "visible",
          "locators": [
            {
              "kind": "testid",
              "value": "session-email"
            },
            {
              "kind": "css",
              "value": "nav .who"
            }
          ],
          "description": "Session email visible in the nav"
        }
      ],
      "timingBaselineKey": "s3"
    }
  ]
}