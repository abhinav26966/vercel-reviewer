{
  "specVersion": 3,
  "flowId": "flw_inventory",
  "projectId": "prj_862ymcrku4xal4",
  "name": "Inventory",
  "description": "Open the inventory, verify the page renders.",
  "tier": "standard",
  "persona": "default",
  "startPath": "/inventory",
  "steps": [
    {
      "id": "s4",
      "title": "Open inventory",
      "intent": "Inventory page renders with the pack list (or empty state)",
      "action": {
        "type": "navigate",
        "path": "/inventory"
      },
      "settle": {
        "strategy": "networkidle",
        "timeoutMs": 8000
      },
      "postConditions": [
        {
          "kind": "url",
          "assert": "pathMatches",
          "value": "^/inventory$"
        },
        {
          "kind": "dom",
          "assert": "textMatches",
          "locators": [
            {
              "kind": "css",
              "value": "main h1"
            }
          ],
          "value": "Inventory",
          "description": "Inventory heading rendered"
        }
      ],
      "timingBaselineKey": "s4"
    }
  ]
}